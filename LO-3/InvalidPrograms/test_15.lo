// bad test case
// Main has a non-empty field list, so it has no zero-arg constructor for the entry point
// expected compile error: E_MAIN_NO_ZERO_ARG_CONSTRUCTOR
// Author: CS 378H course staff (Fall 2026)

class room(int length, breadth, height;) [
    room(){
        length = 4;
        breadth = 5;
        height = 6;
    }
] {
    int getLength() {
        return length;
    }
    int getBreadth() {
        return breadth;
    }
}

class Main(room r;) {
    int main(){
        r = new room();
        return this.getArea(r);
    }
    int getArea(room r) {
        return (r.getLength() * r.getBreadth());
    }
}
