// bad test case
// Call a method from null
// expected compile error: E_NULL_LITERAL_RECEIVER
// Author: Aaron Wollman (Summer 2021)

class Main() {
    int main(){
        MyClass a;
        a = new MyClass();
        return null.getValue();
    }
}

class MyClass() [
    MyClass(){
        ;
    }
] {
    int getValue(){
        return 5;
    }
}
