// bad test case
// cannot use reserved words as method names
// expected compile error: E_RESERVED_KEYWORD_AS_IDENTIFIER
// Author: Tyler Collins (Summer 2022)

class Main() {
    int main(){
        Condition condition;
        Waiter waiter;
        bool wait;
        condition = new Condition();
        waiter = new Waiter(condition);
        wait = waiter.while();
        return condition.getState();
    }
}

class Condition(int state;) [
    Condition() {
        state = 0;
    }
] {
    bool break() {
        state = (state + 1);
        return (state > 10);
    }
    int getState() {
        return state;
    }
}

class Waiter(Condition condition;) [
    Waiter(Condition cond) {
        condition = cond;
    }
] {
    bool while() {
        while (!condition.break()) { ; }
        return true;
    }
}
