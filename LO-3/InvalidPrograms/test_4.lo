// bad test case
// Call written without `new` (`Tester(5)`) plus a method header missing its `()` — both parse errors
// expected compile error: E_PARSE_PHASE_OTHER
// Author: Aaron Wollman (Summer 2021)

class Main() {
    int main(){
        Tester a;
        a = Tester(5);
        return a.getA();
    }
}

class Tester(int A;) [
    Tester(int a){
        A = a;
    }
] {
    int getA{
        return A;
    }
}
