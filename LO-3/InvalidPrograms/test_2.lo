// bad test case
// Inappropriate method chains
// expected compile error: E_PARSE_PHASE_OTHER
// Author: Aaron Wollman (Summer 2021)

class Main() {
    int main(){
        return new Adder(5).add(6).add(7).getValue();
    }
}

class Adder(int val;) [
    Adder(int value){
        val = value;
    }
] {
    Adder add(int addVal){
        return new Adder((val+addVal));
    }
    int getValue(){
        return val;
    }
}
