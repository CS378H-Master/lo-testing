// good test case
// StringBuilder class and Short-Circuiting
// main method return value: 43
// migrated 2026-06-03: int sentinel; success iff this.orig_main() == "zYxzYx"
// Author: Aaron Wollman (Summer 2021)

class Main() {
    String orig_main(){
        StringBuilder sb;
        bool indicator;
        sb = new StringBuilder();
        if((sb.isEmpty() | sb.append("abc"))){
            indicator = sb.append("xYz");
        }
        else{
            indicator = sb.append("123");
        }
        if(((!sb.reverse()) & sb.multiply(5))){
            indicator = sb.multiply(0);
        }
        else{
            indicator = sb.multiply(2);
        }
        return sb.getString();
    }
    int main(){
        return ((this.orig_main() = "zYxzYx") ? 43 : 0);
    }
}

class StringBuilder(String value;) [
    StringBuilder(){
        value = "";
    }
] {
    bool isEmpty(){
        return (value = "");
    }
    bool append(String appValue){
        value = (value + appValue);
        return true;
    }
    bool multiply(int times){
        value = (value * times);
        return true;
    }
    bool reverse(){
        value = (~value);
        return true;
    }
    String getString(){
        return value;
    }
}
