// *Good testcase*
// String Operations
// main return value: 71
// migrated 2026-06-03: int sentinel; success iff orig_main() == "azzzzzc"
// Author: Tyler Collins


String orig_main() {
    return concatenator(concatenator("a", replicator("z", 5)), "c");
}

String replicator(String input, int repetitions) {
    return (input * repetitions);
}

String concatenator(String a, String b) {
    return (a + b);
}

int main() {
    return ((orig_main() = "azzzzzc") ? 71 : 0);
}
