// *Good testcase*
// Test literals in while/if statements, ternary expressions
// main return value: 1
// migrated 2026-06-03: int sentinel; success iff orig_main() is true
// Author: Aaron Wollman

bool isDivisible(int a, int b){
    return ((a % b) = 0);
}

bool orig_main(){
    int a, b;
    a = 61;
    while (true){
        if ((!(a = 61))){
            break;
        }
        else {
            a = 93;
        }
    }
    b = 42;
    if (false){
        b = 105;
    }
    else {
        b = 3;
    }
    if (((b > a) ? isDivisible(b, a) : isDivisible(a, b)))
    {
        return true;
    }
    else {
        return false;
    }
    return false;
}

int main() {
    return (orig_main() ? 1 : 0);
}
