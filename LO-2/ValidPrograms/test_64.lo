// *Good testcase*
// String Operations
// main return value: 64
// migrated 2026-06-03: int sentinel; success iff orig_main() == "alternate result"
// Author: Tyler Collins


String orig_main() {
    return concatenator(concatenator("a", replicator("b", 5)), "c");
}

String replicator(String input, int repetitions) {
    return (input * repetitions);
}

String concatenator(String a, String b) {
    String c;
    c = "tluser etanretla";
    if ((a < b)) {
        return (~c);
    } else {
        return (a + b);
    }
    return "";
}

int main() {
    return ((orig_main() = "alternate result") ? 64 : 0);
}
