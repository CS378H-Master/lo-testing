// *Good testcase*
// The while-loop executes only once because of the break
// main return value: 56
// migrated 2026-06-03: int sentinel; success iff orig_main() == "HelloHello"
// Author: Fall 2021 TAs


String foo(String a) {
    int b;
    String c;
    b=5;
    while((b>0)) {
        c = (a*2);
        b = (b-1);
        break;
    }
    return c;
}

String orig_main() {
    return foo("Hello");
}

int main() {
    return ((orig_main() = "HelloHello") ? 56 : 0);
}
