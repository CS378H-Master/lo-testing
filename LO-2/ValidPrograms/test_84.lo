// *Good testcase*
// Test string concat, short circuit on OR
// main return value: 84
// migrated 2026-06-03: int sentinel; success iff orig_main() == "black cat"
// Author: Aaron Wollman

String addCat(String str){
    str = (str + " cat");
    return str;
}

String addDog(String str){
    str = (str + " dog");
    return str;
}

String orig_main(){
    String str;
    str = "black";
    if ((((("a" < str) | (str < "z")) | (str = "a")) | (str = "z"))) {
        str = addCat(str);
    } else {
        str = addDog(str);
    }
    return str;
}

int main() {
    return ((orig_main() = "black cat") ? 84 : 0);
}
