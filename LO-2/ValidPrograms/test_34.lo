// *Good testcase*
// Test string accumlation in while loop
// main return value: 34
// migrated 2026-06-03: int sentinel; success iff orig_main() == "abcabcabcabcabcabcabcabcabc"
// Author: Tyler Collins

String orig_main() {
    String target, result;
    int counter;
    target = ("abc" * 10);
    result = "abc";
    counter = 0;
    while ((accumulate(result, "abc") < target)) {
        result = (((counter % 3) = 0) ? accumulate(result, "abc") : result);
        counter = (counter + 1);
        if (((result = target) | (result > target))) {
            return result;
        } else { ; }
    }
    return result;
}

String accumulate(String result, String addend) {
    return (result + addend);
}

int main() {
    return ((orig_main() = "abcabcabcabcabcabcabcabcabc") ? 34 : 0);
}
