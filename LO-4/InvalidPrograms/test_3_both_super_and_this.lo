// bad test case
// Constructor body contains both super(...) and this(...) delegations — the grammar admits
// at most one delegation, as the optional first statement, so this is a parse error.
// expected compile error: E_DELEGATION_BOTH_SUPER_AND_THIS

class Parent ( int x; ) [
    Parent(int v) { x = v; }
] { }

class Child ( int y; ) extends Parent [
    Child() { this(10); }
    Child(int v) {
        super(v);
        this();
    }
] { }

class Main () {
    int main() {
        return 0;
    }
}
