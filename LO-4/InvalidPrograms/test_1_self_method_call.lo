// good test case
// Self method call via this.method()
// main method return value: 2

class Main () {
    int main() {
        Counter c;
        c = new Counter();
        c.incr_twice();
        return c.get();
    }
}

class Counter ( int count; ) [
    Counter() { count = 0; }
] {
    void increment() {
        count = (count + 1);
    }
    int get() { return count; }
    void incr_twice() {
        this.increment();
        this.increment();
    }
}
