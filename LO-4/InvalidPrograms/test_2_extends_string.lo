// bad test case
// Class extending String prohibited. String is a type keyword, not a <ClassName>,
// so this is rejected by the parser.
// expected compile error: E_RESERVED_KEYWORD_AS_IDENTIFIER

class FancyString ( ) extends String [
    FancyString() { ; }
] {
    int describe() { return 1; }
}

class Main () {
    int main() {
        return 0;
    }
}
