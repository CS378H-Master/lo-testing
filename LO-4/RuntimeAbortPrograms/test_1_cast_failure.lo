// runtime abort test case
// Cast failure when downcasting to sibling type
// expected exit code: 101
// expected stderr substring: lo_cast_check: cannot cast Dog to Cat

class Main () {
    int main() {
        Animal a;
        Cat c;
        a = new Dog();
        c = ( (Cat) a );
        return 0;
    }
}

class Animal ( ) [ Animal() { ; } ] {
    int who() { return 1; }
}

class Cat extends Animal ( ) [
    Cat() { super(); }
] {
    int meow() { return 2; }
}

class Dog extends Animal ( ) [
    Dog() { super(); }
] {
    int bark() { return 3; }
}
